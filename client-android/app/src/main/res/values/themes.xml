<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Tema oscuro permanente (Material 3). -->
    <style name="Theme.OpenWirelessDisplay" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorPrimaryDark">@color/accent_dark</item>
        <item name="colorOnPrimary">@color/text</item>
        <item name="colorSecondary">@color/success</item>
        <item name="android:colorBackground">@color/bg</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text</item>
        <item name="android:statusBarColor">@color/bg</item>
        <item name="android:navigationBarColor">@color/bg</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Variante a pantalla completa para la actividad de visualizacion. -->
    <style name="Theme.OpenWirelessDisplay.Fullscreen" parent="Theme.OpenWirelessDisplay">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:colorBackground">@color/black</item>
    </style>

</resources>
