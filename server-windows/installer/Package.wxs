<?xml version="1.0" encoding="utf-8"?>
<!--
  Instalador MSI de OpenWirelessDisplay Server (WiX 4+/6+/7+).
  La version proviene de version.wxi, generado por execution/bump_version.py.
  Build:  wix build installer/Package.wxs -arch x64 -o OpenWirelessDisplay-Server-<ver>.msi
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:fw="http://wixtoolset.org/schemas/v4/wxs/firewall">
  <?include version.wxi ?>

  <Package Name="OpenWirelessDisplay Server"
           Manufacturer="OpenWirelessDisplay"
           Version="$(var.ProductVersion)"
           UpgradeCode="6F2A1B3C-9D4E-4F50-A1B2-7C8D9E0F1A2B"
           Scope="perMachine"
           Compressed="yes">

    <SummaryInformation Description="Servidor de pantalla externa inalambrica (open source, MIT)" />

    <MajorUpgrade DowngradeErrorMessage="Ya hay una version mas reciente de !(bind.property.ProductName) instalada." />
    <MediaTemplate EmbedCab="yes" />

    <!-- Directorios de instalacion -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="OpenWirelessDisplay" />
    </StandardDirectory>
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppProgramMenuDir" Name="OpenWirelessDisplay" />
    </StandardDirectory>

    <!-- Caracteristica principal -->
    <Feature Id="Main" Title="OpenWirelessDisplay Server" Level="1">
      <ComponentGroupRef Id="ServerFiles" />
      <ComponentRef Id="AppShortcuts" />
      <ComponentRef Id="FirewallRules" />
    </Feature>

    <!-- Harvesting automatico de todo el output self-contained publicado -->
    <ComponentGroup Id="ServerFiles" Directory="INSTALLFOLDER">
      <Files Include="publish\**" />
    </ComponentGroup>

    <!-- Accesos directos (Menu Inicio) -->
    <Component Id="AppShortcuts" Directory="AppProgramMenuDir" Guid="A3B4C5D6-1234-4567-89AB-CDEF01234567">
      <Shortcut Id="StartMenuShortcut"
                Name="OpenWirelessDisplay Server"
                Description="Servidor de pantalla externa inalambrica"
                Target="[INSTALLFOLDER]OpenWirelessDisplay.Server.exe"
                WorkingDirectory="INSTALLFOLDER" />
      <RemoveFolder Id="CleanProgramMenuDir" Directory="AppProgramMenuDir" On="uninstall" />
      <RegistryValue Root="HKLM"
                     Key="Software\OpenWirelessDisplay\Server"
                     Name="installed"
                     Type="integer" Value="1" KeyPath="yes" />
    </Component>

    <!-- Reglas de Firewall (el instalador corre elevado y puede crearlas).
         Sin esto, Windows bloquea el trafico entrante del telefono (descubrimiento y stream). -->
    <Component Id="FirewallRules" Directory="INSTALLFOLDER" Guid="B7C8D9E0-2345-4678-9ABC-DEF012345678">
      <RegistryValue Root="HKLM" Key="Software\OpenWirelessDisplay\Server"
                     Name="firewall" Type="integer" Value="1" KeyPath="yes" />
      <fw:FirewallException Id="OWDProgram" Name="OpenWirelessDisplay Server"
                            Program="[INSTALLFOLDER]OpenWirelessDisplay.Server.exe"
                            Scope="any" Profile="all" />
      <fw:FirewallException Id="OWDmDNS" Name="OpenWirelessDisplay mDNS (UDP 5353)"
                            Port="5353" Protocol="udp" Scope="any" Profile="all" />
      <fw:FirewallException Id="OWDStream" Name="OpenWirelessDisplay Stream (TCP 7345)"
                            Port="7345" Protocol="tcp" Scope="any" Profile="all" />
    </Component>

  </Package>
</Wix>
